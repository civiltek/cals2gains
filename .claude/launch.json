{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (app móvil)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "Static preview (website)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "website", "-p", "5050", "-c-1", "--silent"],
      "port": 5050,
      "autoPort": false
    },
    {
      "name": "Firebase Hosting (landing cals2gains.com)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["serve", "--only", "hosting"],
      "port": 5000,
      "autoPort": true
    }
  ]
}
