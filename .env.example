# ============================================
# Cals2Gains - Variables de entorno
# ============================================
# Copia este archivo a .env y rellena tus valores
# NUNCA compartas tu archivo .env con nadie

# OpenAI API Key (desde platform.openai.com)
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Firebase (desde Firebase Console > Configuración del proyecto)
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Sign-In (desde Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-abc.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-ios.apps.googleusercontent.com

# RevenueCat (desde app.revenuecat.com > API Keys)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...

# ElevenLabs - Text-to-Speech (desde elevenlabs.io > Profile + API Key)
ELEVENLABS_API_KEY=sk_...

# Notion Integration (desde notion.so/my-integrations)
NOTION_API_KEY=ntn_...
NOTION_PARENT_PAGE=<id-de-la-pagina-padre-32-chars>
