# EAS Build ignore file
# Unlike .gitignore, we INCLUDE .env so API keys reach the build server

node_modules/
.expo/
dist/
web-build/
*.tsbuildinfo
*.log
npm-debug.*

# Marketing & non-build assets (brand-assets/ is kept — fonts & logos are needed at build time)
marketing/
Campaign_F1/
instagram/
store-screenshots/
public/
docs/

# Git & IDE
.git/
.vscode/

# Sensitive files NOT needed for build
google-play-service-account.json

# Lock file generated by npm 11 (Node 24) is incompatible with EAS build server (Node 18/20).
# Excluding it forces EAS to run `npm install` from package.json directly.
package-lock.json

# Metro config causes Node 24 ESM crash on Windows during EAS CLI fingerprinting.
# Rebuilt on server via eas.json prebuildCommand.
metro.config.js
