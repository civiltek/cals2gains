# Copy this file to `.env` and fill both values.
# Never commit `.env` to git. See .gitignore.

# From @BotFather after creating the bot.
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# The chat (private or group) where approvals will happen.
# If you don't know it yet, leave empty and run `test_connection.py` —
# it will detect the chat_id from your first /start message and write it here.
TELEGRAM_CHAT_ID=
