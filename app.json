{
  "expo": {
    "name": "Cals2Gains",
    "slug": "cals2gains",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cals2gains",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#17121D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.civiltek.cals2gains",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cals2Gains necesita acceso a la camara para analizar tus comidas y escanear codigos de barras.",
        "NSPhotoLibraryUsageDescription": "Cals2Gains necesita acceso a tus fotos.",
        "NSMicrophoneUsageDescription": "Cals2Gains usa el microfono para registrar comidas por voz.",
        "NSHealthShareUsageDescription": "Cals2Gains lee tus datos de salud (pasos, calorias, ejercicio, peso) para adaptar tus macros automaticamente.",
        "NSHealthUpdateUsageDescription": "Cals2Gains sincroniza tu peso con Apple Health.",
        "NSHealthClinicalHealthRecordsShareUsageDescription": "Cals2Gains no accede a tus historiales clinicos medicos. Esta descripcion es requerida por Apple porque el entitlement de HealthKit la incluye por defecto.",
        "CFBundleLocalizations": [
          "en",
          "es"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true,
        "com.apple.developer.healthkit.access": ["health-records"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealthAndFitness",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserId",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotos",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePurchaseHistory",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
          }
        ],
        "NSPrivacyTracking": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#17121D"
      },
      "package": "com.civiltek.cals2gains",
      "versionCode": 1,
      "useNextNotificationsApi": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.WRITE_WEIGHT",
        "android.permission.health.READ_BASAL_METABOLIC_RATE",
        "android.permission.health.READ_SLEEP"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      ["./plugins/withMinSdkVersion", { "minSdkVersion": 26 }],
      "expo-router",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.623010472348-a1mb9rqr8jlq3jkhi043bpacg6b4f9it"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a camara para analizar comida."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos."
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.21"
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-secure-store",
      [
        "react-native-health-connect",
        {
          "requestPermissionsOnFirstLaunch": false
        }
      ],
      [
        "react-native-health",
        {
          "healthSharePermission": "Cals2Gains lee tus datos de salud (pasos, calorias, ejercicio, peso) para adaptar tus macros automaticamente.",
          "healthUpdatePermission": "Cals2Gains sincroniza tu peso con Apple Health."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#9C8CFF",
          "defaultChannel": "reminders",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "381120d5-3866-4b97-af00-4c6840768327"
      }
    },
    "owner": "civiltek"
  }
}