{
  "expo": {
    "name": "Cals2Gains",
    "slug": "cals2gains",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cals2gains",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#17121D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.civiltek.cals2gains",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cals2Gains necesita acceso a la camara para analizar tus comidas y escanear codigos de barras.",
        "NSPhotoLibraryUsageDescription": "Cals2Gains necesita acceso a tus fotos.",
        "NSMicrophoneUsageDescription": "Cals2Gains usa el microfono para registrar comidas por voz.",
        "NSHealthShareUsageDescription": "Cals2Gains lee tus datos de salud (pasos, calorias, ejercicio, peso) para adaptar tus macros automaticamente.",
        "NSHealthUpdateUsageDescription": "Cals2Gains sincroniza tu peso con Apple Health.",
        "CFBundleLocalizations": [
          "en",
          "es",
          "en",
          "es"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#17121D"
      },
      "package": "com.civiltek.cals2gains",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a camara para analizar comida."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos."
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.21"
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "381120d5-3866-4b97-af00-4c6840768327"
      }
    },
    "owner": "civiltek"
  }
}
