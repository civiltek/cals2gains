{
  "expo": {
    "name": "Cals2Gains",
    "slug": "cals2gains",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cals2gains",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.civiltek.cals2gains",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cals2Gains necesita acceso a la camara para analizar tus comidas.",
        "NSPhotoLibraryUsageDescription": "Cals2Gains necesita acceso a tus fotos.",
        "CFBundleLocalizations": [
          "en",
          "es"
        ]
      },
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.civiltek.cals2gains",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a camara para analizar comida."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "381120d5-3866-4b97-af00-4c6840768327"
      }
    },
    "owner": "civiltek"
  }
}
